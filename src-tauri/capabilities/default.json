{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Publisher Rocket Reader",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:webview:allow-set-webview-focus",
    "clipboard-manager:allow-write-text",
    "shell:allow-execute",
    "shell:allow-open"
  ]
}
